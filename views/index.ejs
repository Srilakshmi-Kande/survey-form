<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-100">
    <div class="main w-full min-h-screen">
        <div class="form w-full flex justify-center items-center my-5">
            <form action="/submit" method="post" class="w-full p-10 lg:w-1/3 border-2 border-t-5 rounded-md bg-white border-blue-700">
                <div>
                    <h1 class="text-3xl mt-2 mb-2 text-blue-700"><b>Survey Form</b></h1>
                    <p class="mt-3 mb-3 pt-3 pb-3">
                        This survey is to know about your educational details.<br>
                        Please fill your details here.
                    </p>
                </div>

                <label class="text-blue-800">Name</label><br>

                <input class="w-full rounded-md border-2 border-blue-600  px-5 py-2 mt-1 mb-3 focus:outline-none focus:ring-1 focus:ring-blue-900" 
                    type="text" 
                    placeholder="Enter your name" 
                    name="username" 
                    required
                ><br>

                <label class="text-blue-800">Email ID</label><br>

                <input class="w-full rounded-md border-2 border-blue-600  px-5 py-2 mt-1 mb-3 focus:outline-none focus:ring-1 focus:ring-blue-900" 
                    type="email" 
                    placeholder="Enter your email" 
                    name="email" 
                    required
                ><br>

                <label class="text-blue-800">Mobile Number</label><br>

                <input class="w-full rounded-md border-2 border-blue-600  px-5 py-2 mt-1 mb-3 focus:outline-none focus:ring-1 focus:ring-blue-900" 
                    type="tel" 
                    maxlength="10" 
                    pattern="[0-9]{10}" 
                    placeholder="Enter your mobile number" 
                    name="mobile" 
                    required
                ><br>

                <label class="text-blue-800">College/University Name</label><br>

                <input class="w-full rounded-md border-2 border-blue-600  px-5 py-2 mt-1 mb-3 focus:outline-none focus:ring-1 focus:ring-blue-900" 
                    type="text" 
                    placeholder="Enter your college name" 
                    name="college" 
                    required
                ><br>

                <label class="text-blue-800">Roll No</label><br>

                <input class="w-full rounded-md border-2 border-blue-600  px-5 py-2 mt-1 mb-3 focus:outline-none focus:ring-1 focus:ring-blue-900" 
                    type="number" 
                    placeholder="Enter your rollno" 
                    name="rollno" 
                    required
                ><br>

                <label class="text-blue-800">Branch</label><br>

                <input class="w-full rounded-md border-2 border-blue-600  px-5 py-2 mt-1 mb-3 focus:outline-none focus:ring-1 focus:ring-blue-900" 
                    type="text" 
                    placeholder="Enter your branch" 
                    name="branch" 
                    required
                ><br>

                <label class="text-blue-800">Year</label><br>

                <input class="w-full rounded-md border-2 border-blue-600  px-5 py-2 mt-1 mb-3 focus:outline-none focus:ring-1 focus:ring-blue-900" 
                    type="number" 
                    placeholder="Year of study(1-4)" 
                    name="year" 
                    required
                ><br>

                <label class="text-blue-800">About your interests</label><br>

                <textarea class="w-full rounded-md border-2 border-blue-600  mt-2 px-5 py-2 resize-none focus:outline-none focus:ring-1 focus:ring-blue-900" 
                    placeholder="write about you here...." 
                    name="interests"
                ></textarea><br>

                <input class="mt-2 bg-blue-500 text-white text-xl px-5 py-2 rounded-md hover:bg-blue-700" 
                    type="submit" 
                    value="Submit"
                />
            </form>
        </div>
    </div>
</body>
</html>